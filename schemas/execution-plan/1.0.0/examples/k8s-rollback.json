{
  "version": "1.0.0",
  "plan_id": "7c9e6679-7425-40de-944b-e07fc1f90ae7",
  "id": "k8s_ops.rollback",
  "session_id": "session-abc-123",
  "created_at": "2025-02-27T14:30:00Z",
  "expires_at": "2025-02-27T15:30:00Z",
  "execution_mode": "governance_driven",
  "description_for_user": "Roll back deployment 'api-server' to previous revision in production namespace",
  "surface_effects": {
    "touches": [
      "kubernetes/deployments/api-server",
      "kubernetes/replicasets/api-server-*",
      "incident-system/INC-12345"
    ],
    "modifies": true,
    "creates": false,
    "deletes": false
  },
  "intent": {
    "summary": "Roll back api-server deployment to last known good revision due to elevated error rates",
    "category": "deploy",
    "risk_level": "high",
    "user_message": "Roll back api-server, error rates are spiking",
    "five_w_one_h": {
      "who": "SRE on-call",
      "what": "rollback deployment to previous revision",
      "where": "production kubernetes cluster, default namespace",
      "when": "immediate, emergency change",
      "why": "elevated error rates detected post-deploy",
      "how": "kubectl rollout undo"
    }
  },
  "user_context": {
    "actor_id": "sre-jane",
    "role": "site_reliability_engineer",
    "trust_level": "high",
    "team": "platform",
    "access_tier": "prod-admin",
    "oncall": true
  },
  "scope": {
    "target_system": "kubernetes",
    "environment": "production",
    "allowed_systems": ["kubernetes", "incident-system"],
    "forbidden_systems": ["database", "secrets-manager"]
  },
  "constraints": {
    "allow_unplanned": false,
    "max_total_operations": 10,
    "max_duration_ms": 600000,
    "require_sequential": true,
    "forbidden_paths": [],
    "forbidden_commands": ["kubectl delete namespace", "kubectl delete deployment"],
    "data_sensitivity": "internal",
    "require_approval": {
      "model": "manager",
      "incident_reference_required": true,
      "ticket_reference_required": false
    }
  },
  "invariants": {
    "must_hold": [
      "deployment.replicas >= 1",
      "cluster.reachable == true"
    ],
    "preconditions": [
      "incident_id is present",
      "previous revision exists in history"
    ],
    "refusal_conditions": [
      "no previous revision available",
      "deployment not found"
    ]
  },
  "steps": [
    {
      "step": 1,
      "action": "Verify incident reference",
      "inputs": {
        "required": [
          { "name": "incident_id", "type": "string", "source": "user" }
        ],
        "optional": []
      },
      "do": {
        "tool": "incident-system",
        "operation": "get",
        "target": "INC-12345",
        "parameters": {}
      },
      "verify": {
        "checks": [
          {
            "name": "incident_exists",
            "evidence": "incident system response",
            "pass_condition": "incident.status in ['open', 'in_progress']"
          }
        ]
      },
      "on_fail": {
        "behavior": "abort_plan",
        "refuse_if": ["incident_id is missing"]
      },
      "audit": {
        "record_outputs": [
          { "name": "incident_status", "type": "string", "write_to": "log" }
        ]
      }
    },
    {
      "step": 2,
      "action": "Get deployment history",
      "depends_on": [1],
      "inputs": {
        "required": [
          { "name": "deployment_name", "type": "string", "source": "parameter" },
          { "name": "namespace", "type": "string", "source": "parameter" }
        ],
        "optional": []
      },
      "do": {
        "tool": "k8s",
        "operation": "rollout_history",
        "target": "deployment/api-server",
        "parameters": { "namespace": "default" }
      },
      "verify": {
        "checks": [
          {
            "name": "has_previous_revision",
            "evidence": "rollout history output",
            "pass_condition": "history.revisions.length >= 2"
          }
        ]
      },
      "on_fail": {
        "behavior": "abort_plan",
        "refuse_if": ["history.revisions.length < 2"]
      },
      "audit": {
        "record_outputs": [
          { "name": "revision_list", "type": "array", "write_to": "log" },
          { "name": "target_revision", "type": "integer", "write_to": "log" }
        ]
      }
    },
    {
      "step": 3,
      "action": "Execute rollback",
      "depends_on": [2],
      "requires_confirmation": true,
      "inputs": {
        "required": [
          { "name": "deployment_name", "type": "string", "source": "parameter" },
          { "name": "target_revision", "type": "integer", "source": "previous_step" }
        ],
        "optional": []
      },
      "do": {
        "tool": "k8s",
        "operation": "rollout_undo",
        "target": "deployment/api-server",
        "parameters": {
          "namespace": "default",
          "to_revision": "previous"
        },
        "allow": {
          "commands": [
            { "pattern": "kubectl rollout undo deployment/api-server*", "type": "glob" }
          ]
        },
        "deny": {
          "commands": [
            { "pattern": "*--force*", "type": "glob" },
            { "pattern": "*delete*", "type": "glob" }
          ]
        }
      },
      "verify": {
        "checks": [
          {
            "name": "rollout_started",
            "evidence": "kubectl output",
            "pass_condition": "output contains 'rolled back'"
          }
        ]
      },
      "on_fail": {
        "behavior": "abort_plan",
        "refuse_if": ["cluster_unreachable == true"],
        "required_log_entries": ["error_message", "kubectl_output"]
      },
      "audit": {
        "record_outputs": [
          { "name": "rollback_output", "type": "string", "write_to": "log" },
          { "name": "new_revision", "type": "integer", "write_to": "incident-system" }
        ]
      }
    },
    {
      "step": 4,
      "action": "Verify rollback success",
      "depends_on": [3],
      "timeout_ms": 120000,
      "inputs": {
        "required": [
          { "name": "deployment_name", "type": "string", "source": "parameter" }
        ],
        "optional": []
      },
      "do": {
        "tool": "k8s",
        "operation": "rollout_status",
        "target": "deployment/api-server",
        "parameters": { "namespace": "default", "watch": true, "timeout": "2m" }
      },
      "verify": {
        "checks": [
          {
            "name": "rollout_complete",
            "evidence": "rollout status output",
            "pass_condition": "status == 'successfully rolled out'"
          },
          {
            "name": "pods_ready",
            "evidence": "deployment status",
            "pass_condition": "deployment.readyReplicas == deployment.replicas"
          }
        ]
      },
      "on_fail": {
        "behavior": "complete_with_warning",
        "refuse_if": [],
        "required_log_entries": ["rollout_status", "pod_statuses"]
      },
      "audit": {
        "record_outputs": [
          { "name": "final_status", "type": "string", "write_to": "log" },
          { "name": "ready_replicas", "type": "integer", "write_to": "log" }
        ]
      }
    },
    {
      "step": 5,
      "action": "Update incident with results",
      "depends_on": [4],
      "inputs": {
        "required": [
          { "name": "incident_id", "type": "string", "source": "user" },
          { "name": "rollback_status", "type": "string", "source": "previous_step" }
        ],
        "optional": []
      },
      "do": {
        "tool": "incident-system",
        "operation": "add_comment",
        "target": "INC-12345",
        "parameters": {
          "comment": "Rollback completed. Deployment api-server rolled back to previous revision."
        }
      },
      "verify": {
        "checks": [
          {
            "name": "comment_added",
            "evidence": "incident system response",
            "pass_condition": "response.status == 200"
          }
        ]
      },
      "on_fail": {
        "behavior": "complete_with_warning",
        "refuse_if": []
      },
      "audit": {
        "record_outputs": [
          { "name": "incident_update_status", "type": "string", "write_to": "log" }
        ]
      }
    }
  ],
  "abort_conditions": [
    {
      "condition": "cluster_unreachable == true",
      "reason": "Lost connection to Kubernetes cluster",
      "check_frequency": "before_each_step"
    },
    {
      "condition": "deployment.replicas == 0",
      "reason": "Deployment has no replicas - unsafe to continue",
      "check_frequency": "after_each_step"
    },
    {
      "condition": "incident.status == 'resolved'",
      "reason": "Incident was resolved externally - aborting rollback",
      "check_frequency": "before_each_step"
    }
  ],
  "metadata": {
    "generated_by": "planner-v1",
